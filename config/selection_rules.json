{
  "$schema": "https://example.com/schemas/selection-rules.json",
  "version": 1,
  "skip_compression": {
    "extensions": [".7z", ".gz", ".jpg", ".jpeg", ".mov", ".mp4",
                   ".png", ".wav", ".webp", ".heic", ".heif", ".z",
                   ".flac", ".pdf", ".aac"],
    "file_types": [
      "Audio_FLAC",
      "Document_PDF"
    ],
    "entropy_threshold": 7.5
  },
  "rules": [
    {
      "fileType": 0,
      "algorithm": "zstd",
      "level": 22,
      "rationale": "Source code: zstd level 22 for cold storage",
      "skip": false,
      "fallbackAlgorithm": "brotli",
      "fallbackLevel": 11
    },
    {
      "fileType": 6,
      "algorithm": "",
      "level": 0,
      "rationale": "JPEG: already compressed, skip",
      "skip": true,
      "fallbackAlgorithm": "",
      "fallbackLevel": 0
    },
    {
      "fileType": 14,
      "algorithm": "",
      "level": 0,
      "rationale": "FLAC: already lossless compressed, secondary compression < 10% gain",
      "skip": true,
      "fallbackAlgorithm": "",
      "fallbackLevel": 0
    },
    {
      "fileType": 18,
      "algorithm": "",
      "level": 0,
      "rationale": "PDF: internal compression often sufficient, < 5% gain",
      "skip": true,
      "fallbackAlgorithm": "",
      "fallbackLevel": 0
    }
  ]
}